#!/usr/bin/env bash
#
# bootstrap installs things.
# Adapted from https://github.com/holman/dotfiles

DOTFILES_ROOT="`pwd`"
cd $DOTFILES_ROOT

mkdir ~/.config/ >/dev/null 2>&1

set -e

echo ''

info () {
    printf "  [ \033[00;34m..\033[0m ] $1"
}

user () {
    printf "\r  [ \033[0;33m?\033[0m ] $1 "
}

success () {
    printf "\r\033[2K  [ \033[00;32mOK\033[0m ] $1\n"
}

fail () {
    printf "\r\033[2K  [\033[0;31mFAIL\033[0m] $1\n"
    echo ''
    exit
}

setup_gitconfig () {
    if ! [ -f git/gitconfig.symlink ]
    then
        info 'setup gitconfig'

        git_credential='cache'

        user ' - What is your github author name?'
        read -e git_authorname
        user ' - What is your github author email?'
        read -e git_authoremail

        sed -e "s/AUTHORNAME/$git_authorname/g" -e "s/AUTHOREMAIL/$git_authoremail/g" -e "s/GIT_CREDENTIAL_HELPER/$git_credential/g" git/gitconfig.symlink.example > git/gitconfig.symlink

        success 'gitconfig'
    fi
}

link_files () {
    ln -s $1 $2
    success "linked $1 to $2"
}

install_dotfiles () {
    info 'installing dotfiles'

    overwrite_all=false
    backup_all=false
    skip_all=false

    for source in `find $DOTFILES_ROOT -maxdepth 2 -name \*.symlink -o -name \*.xdgconfig`
    do
        if [[ $source == *.symlink ]]
        then
            dest="$HOME/.`basename \"${source%.*}\"`"
        else
            dest="$HOME/.config/`basename \"${source%.*}\"`"
        fi

        if [ -f $dest ] || [ -d $dest ]
        then

            overwrite=false
            backup=false
            skip=false

            if [ "$overwrite_all" == "false" ] && [ "$backup_all" == "false" ] && [ "$skip_all" == "false" ]
            then
                user "File already exists: `basename $source`, what do you want to do? [s]kip, [S]kip all, [o]verwrite, [O]verwrite all, [b]ackup, [B]ackup all?"
                read -n 1 action

                case "$action" in
                    o )
                        overwrite=true;;
                    O )
                        overwrite_all=true;;
                    b )
                        backup=true;;
                    B )
                        backup_all=true;;
                    s )
                        skip=true;;
                    S )
                        skip_all=true;;
                    * )
                        ;;
                esac
            fi

            if [ "$overwrite" == "true" ] || [ "$overwrite_all" == "true" ]
            then
                rm -rf $dest
                success "removed $dest"
            fi

            if [ "$backup" == "true" ] || [ "$backup_all" == "true" ]
            then
                mv $dest $dest\.backup
                success "moved $dest to $dest.backup"
            fi

            if [ "$skip" == "false" ] && [ "$skip_all" == "false" ]
            then
                link_files $source $dest
            else
                success "skipped $source"
            fi

        else
            link_files $source $dest
        fi

    done
}

install_packages () {
    info 'installing zsh packages\n'

    case "$(uname -s)" in
        Darwin)
            if ! command -v brew >/dev/null 2>&1; then
                fail 'Homebrew not found. Install it from https://brew.sh and re-run.'
            fi
            brew install pure zsh-autosuggestions zsh-syntax-highlighting zsh-history-substring-search
            success 'zsh packages installed via Homebrew'
            ;;
        Linux)
            if command -v apt-get >/dev/null 2>&1; then
                # Ubuntu, Debian, Raspbian
                sudo apt-get install -y zsh-autosuggestions zsh-syntax-highlighting zsh-history-substring-search
                success 'zsh apt packages installed'
            elif command -v pacman >/dev/null 2>&1; then
                # Arch Linux
                sudo pacman -S --noconfirm zsh-autosuggestions zsh-syntax-highlighting zsh-history-substring-search
                success 'zsh pacman packages installed'
            else
                fail 'No supported package manager found (apt-get or pacman required).'
            fi

            # pure is not in apt/pacman — clone to ~/.zsh/pure
            local pure_dir="$HOME/.zsh/pure"
            if [ -d "$pure_dir" ]; then
                success "pure already present at $pure_dir"
            else
                git clone https://github.com/sindresorhus/pure.git "$pure_dir"
                success "pure cloned to $pure_dir"
            fi
            ;;
        *)
            fail "Unsupported OS: $(uname -s)"
            ;;
    esac
}

setup_gitconfig
install_packages
install_dotfiles

echo ''
echo '  All installed!'
